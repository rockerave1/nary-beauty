# WhatsApp Business API (Meta Cloud API)
# Get these from: https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=your_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# The phone number that receives booking notifications
# Format: country code + number, no spaces or symbols (e.g., 971501234567)
SALON_WHATSAPP_NUMBER=971XXXXXXXXX

# Make.com / Zapier webhook URL (for Google Sheets logging)
# Create a scenario: Custom Webhook → Google Sheets (Add a Row)
MAKE_WEBHOOK_URL=

# Server
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5177
